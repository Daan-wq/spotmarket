// ─────────────────────────────────────────
// WALLET & WITHDRAWALS
// ─────────────────────────────────────────

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  withdrawals WithdrawalRequest[]

  @@index([userId])
}

model WithdrawalRequest {
  id            String           @id @default(cuid())
  walletId      String
  wallet        Wallet           @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount        Decimal          @db.Decimal(12, 2)
  walletAddress String
  network       String           @default("TRC-20")
  currency      String           @default("USDT")
  status        WithdrawalStatus @default(PENDING)
  txHash        String?
  processedBy   String?
  processedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([walletId])
  @@index([status])
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  SENT
  CONFIRMED
  REJECTED
}

// ─────────────────────────────────────────
// SUBSYSTEM A — TRACKING FOUNDATION
// (owned by feat/A-tracking after foundation merges)
// ─────────────────────────────────────────

model MetricSnapshot {
  id                String             @id @default(cuid())
  submissionId      String
  submission        CampaignSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  capturedAt        DateTime           @default(now())
  source            MetricSource
  viewCount         BigInt
  likeCount         Int                @default(0)
  commentCount      Int                @default(0)
  shareCount        Int                @default(0)
  saveCount         Int?
  watchTimeSec      Int?
  reachCount        Int?
  raw               Json?
  // Track-everything extensions (PR1 — additive, populated by per-platform PRs)
  totalInteractions Int?
  followsFromMedia  Int?
  profileVisits     Int?
  profileActivity   Json?
  reactionsByType   Json?

  @@index([submissionId, capturedAt])
  @@index([source])
}

enum MetricSource {
  OAUTH_IG
  OAUTH_TT
  OAUTH_YT
  OAUTH_FB
  OAUTH_FAILED
}

model SubmissionSignal {
  id           String             @id @default(cuid())
  submissionId String
  submission   CampaignSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  type         SignalType
  severity     SignalSeverity
  payload      Json
  createdAt    DateTime           @default(now())
  resolvedAt   DateTime?
  resolvedBy   String?

  @@index([submissionId, type])
  @@index([severity, createdAt])
  @@index([resolvedAt])
}

enum SignalType {
  VELOCITY_SPIKE
  VELOCITY_DROP
  RATIO_ANOMALY
  BOT_SUSPECTED
  LOGO_MISSING
  DUPLICATE
  TOKEN_BROKEN
}

enum SignalSeverity {
  INFO
  WARN
  CRITICAL
}

model AudienceSnapshot {
  id             String            @id @default(cuid())
  connectionType ConnectionType
  connectionId   String
  capturedAt     DateTime          @default(now())
  source         DemographicSource
  kind           AudienceKind      @default(FOLLOWER)
  ageBuckets     Json
  genderSplit    Json
  topCountries   Json
  cities         Json?
  totalReach     Int?
  raw            Json?

  @@index([connectionType, connectionId, capturedAt])
  @@index([connectionType, connectionId, kind, capturedAt])
}

enum ConnectionType {
  IG
  TT
  YT
  FB
}

enum DemographicSource {
  PLATFORM_API
  SELF_REPORT
}

enum AudienceKind {
  FOLLOWER
  ENGAGED
}

/// Escape hatch for full raw API payloads. Pruned by daily cron at 90 days.
/// Keeps `MetricSnapshot` lean while preserving the original API response so
/// we can re-derive metrics if Meta/YouTube/TikTok rename or deprecate fields.
model RawApiResponse {
  id             String         @id @default(cuid())
  submissionId   String?
  connectionType ConnectionType
  connectionId   String
  endpoint       String
  capturedAt     DateTime       @default(now())
  payload        Json

  @@index([submissionId, capturedAt])
  @@index([connectionType, connectionId, capturedAt])
  @@index([capturedAt])
}

/// Instagram Stories — captured by `/api/cron/poll-stories` (hourly) and the
/// webhook handler (when active). Stories expire 24h after posting via API,
/// so we poll within the live window and snapshot lifetime metrics.
/// `postedAt` is the moment the story went live; engagement on a Reel posted
/// near that time is correlated via `StoryReelCorrelation`.
model StoryPost {
  id                String                 @id @default(cuid())
  connectionId      String
  mediaId           String                 @unique
  postedAt          DateTime
  expiresAt         DateTime?
  mediaType         String
  mediaProductType  String
  permalink         String?
  reach             Int?
  views             Int?
  replies           Int?
  follows           Int?
  profileVisits     Int?
  totalInteractions Int?
  shares            Int?
  tapsForward       Int?
  tapsBack          Int?
  tapsExit          Int?
  swipeForward      Int?
  profileActivity   Json?
  lastPolledAt      DateTime               @default(now())
  raw               Json?
  correlations      StoryReelCorrelation[]

  @@index([connectionId, postedAt])
  @@index([postedAt])
}

/// Daily snapshot of platform account state (follower count, video count,
/// totalLikes for TikTok, etc.). Created by the daily
/// `/api/cron/poll-platform-account-snapshots` cron — one row per verified
/// connection per day. Lets us reconstruct "FB page followers over the last
/// 90 days" / "TT followerCount trend" without diffing connection rows.
model PlatformAccountSnapshot {
  id             String         @id @default(cuid())
  connectionType ConnectionType
  connectionId   String
  capturedAt     DateTime       @default(now())
  followerCount  Int?
  followingCount Int?
  totalLikes     BigInt?
  videoCount     Int?
  isVerified     Boolean?
  raw            Json?

  @@index([connectionType, connectionId, capturedAt])
  @@index([capturedAt])
}

/// Daily YouTube channel-level analytics from the Analytics API. Replaces the
/// data we used to compute on-demand and discard. One row per (connection, date).
/// Filled by the daily `/api/cron/poll-yt-analytics` cron.
model YtDailyChannelInsight {
  id                         String   @id @default(cuid())
  connectionId               String
  date                       DateTime @db.Date
  views                      BigInt
  engagedViews               BigInt?
  estimatedMinutesWatched    Int
  averageViewDuration        Int
  averageViewPercentage      Float?
  subscribersGained          Int
  subscribersLost            Int
  likes                      Int
  comments                   Int
  shares                     Int
  redViews                   BigInt?
  estimatedRedMinutesWatched Int?
  trafficSourceBreakdown     Json?
  playbackLocationBreakdown  Json?
  deviceTypeBreakdown        Json?
  contentTypeBreakdown       Json?
  subscribedStatusBreakdown  Json?
  raw                        Json?

  @@unique([connectionId, date])
  @@index([connectionId, date])
}

/// Per-snapshot video retention curve (Facebook Reels / Instagram Reels).
/// `curve` is an ordered array of {tSec, retentionPct} datapoints. Stored as
/// its own table because each snapshot may carry 30+ datapoints — keeping it
/// out of MetricSnapshot makes those rows lighter.
model VideoRetentionCurve {
  id           String       @id @default(cuid())
  submissionId String
  capturedAt   DateTime     @default(now())
  source       MetricSource
  curve        Json

  @@index([submissionId, capturedAt])
}

/// Links a Story to a Reel posted within ±2h by the same creator's IG account.
/// Populated by the daily `correlate-stories-to-reels` job. `deltaMinutes` is
/// signed: negative = story posted before the reel, positive = after.
model StoryReelCorrelation {
  id           String    @id @default(cuid())
  storyId      String
  story        StoryPost @relation(fields: [storyId], references: [id], onDelete: Cascade)
  submissionId String
  deltaMinutes Int
  createdAt    DateTime  @default(now())

  @@unique([storyId, submissionId])
  @@index([submissionId])
  @@index([storyId])
}

// ─────────────────────────────────────────
// SUBSYSTEM B — PERFORMANCE INTELLIGENCE
// (owned by feat/B-intelligence after foundation merges)
// ─────────────────────────────────────────

model ClipperPerformanceScore {
  id               String   @id @default(cuid())
  creatorProfileId String
  computedAt       DateTime @default(now())
  // Weighted composite, 0..100
  score            Float
  // Component scores, all 0..100
  approvalRate     Float
  benchmarkRatio   Float
  trustScore       Float
  deliveryScore    Float
  audienceFit      Float
  sampleSize       Int
  payload          Json?

  @@index([creatorProfileId, computedAt])
  @@index([score])
}

model CampaignBenchmark {
  id              String   @id @default(cuid())
  campaignId      String
  computedAt      DateTime @default(now())
  // Velocity: views per hour
  velocityP10     Float
  velocityP50     Float
  velocityP90     Float
  // Engagement ratios
  likeRatioP50    Float
  likeRatioP90    Float
  commentRatioP50 Float
  commentRatioP90 Float
  // Sample size used to compute
  sampleSize      Int
  windowHours     Int
  payload         Json?

  @@index([campaignId, computedAt])
}

// ─────────────────────────────────────────
// SUBSYSTEM E — NOTIFICATION RULES
// (owned by feat/E-notifications after foundation merges)
// ─────────────────────────────────────────

model NotificationRule {
  id        String                @id @default(cuid())
  userId    String
  type      NotificationType
  channels  NotificationChannel[]
  enabled   Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@unique([userId, type])
  @@index([userId])
}

enum NotificationChannel {
  IN_APP
  EMAIL
  DISCORD
}

// ─────────────────────────────────────────
// COURSES (Duolingo-style routemap)
// ─────────────────────────────────────────

enum CoursePlatform {
  FOUNDATIONS
  TIKTOK
  INSTAGRAM
  YOUTUBE
  X
}

enum BadgeKind {
  LESSON
  SECTION
  COURSE
}

model Course {
  id          String         @id @default(cuid())
  slug        String         @unique
  platform    CoursePlatform
  title       String
  description String?
  order       Int
  isPublished Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  sections CourseSection[]

  @@index([platform, order])
}

model CourseSection {
  id          String  @id @default(cuid())
  courseId    String
  slug        String
  title       String
  order       Int
  isPublished Boolean @default(false)
  badgeSlug   String
  badgeTitle  String

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, slug])
  @@index([courseId, order])
}

model Lesson {
  id          String  @id @default(cuid())
  sectionId   String
  slug        String
  title       String
  contentMd   String
  order       Int
  estMinutes  Int     @default(5)
  isPublished Boolean @default(false)

  section   CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  progress  LessonProgress[]
  attempts  QuizAttempt[]

  @@unique([sectionId, slug])
  @@index([sectionId, order])
}

model QuizQuestion {
  id           String @id @default(cuid())
  lessonId     String
  prompt       String
  optionsJson  Json
  correctIndex Int
  order        Int

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId, order])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime
  earnedBadge Boolean  @default(false)
  quizSkipped Boolean  @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  score       Int
  total       Int
  attemptedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
}

model UserBadge {
  id       String    @id @default(cuid())
  userId   String
  kind     BadgeKind
  refId    String
  earnedAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, refId])
  @@index([userId])
}
