generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// USERS & IDENTITY
// ─────────────────────────────────────────

model User {
  id                                    String   @id @default(cuid())
  supabaseId                            String   @unique
  email                                 String   @unique
  role                                  UserRole
  referralCode                          String?  @unique
  referredBy                            String?
  referralEarnings                      Decimal  @default(0) @db.Decimal(10, 2)
  notifyCampaignAlerts                  Boolean  @default(true)
  notifyPayoutAlerts                    Boolean  @default(true)
  profilePublic                         Boolean  @default(true)
  dismissedFacebookPageWarning          Boolean  @default(false)
  dismissedInstagramProfessionalWarning Boolean  @default(false)
  discordId                             String?  @unique
  discordUsername                       String?
  createdAt                             DateTime @default(now())
  updatedAt                             DateTime @updatedAt

  creatorProfile               CreatorProfile?
  auditLogs                    AuditLog[]
  referralPayouts              ReferralPayout[]              @relation("ReferrerPayouts")
  campaignReferralAttributions CampaignReferralAttribution[] @relation("CampaignReferralReferrer")
  referredCampaignAttributions CampaignReferralAttribution[] @relation("CampaignReferralUser")
  ownedCampaigns               Campaign[]                    @relation("OwnedCampaigns")
  createdDiscordTemplates       DiscordMessageTemplate[]      @relation("DiscordTemplateCreatedBy")
  updatedDiscordTemplates       DiscordMessageTemplate[]      @relation("DiscordTemplateUpdatedBy")
  notifications                Notification[]
  campaignSubmissions          CampaignSubmission[]
  wallet                       Wallet?
  lessonProgress               LessonProgress[]
  quizAttempts                 QuizAttempt[]
  badges                       UserBadge[]

  @@index([supabaseId])
  @@index([role])
  @@index([referralCode])
}

enum UserRole {
  admin
  creator
}

model CreatorProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username            String?  @unique
  displayName         String
  bio                 String?
  avatarUrl           String?
  walletAddress       String?
  tronsAddress        String?
  payoutIban          String?
  payoutAccountName   String?
  payoutSolanaAddress String?
  stripeAccountId     String?
  primaryGeo          String   @default("US")
  totalFollowers      Int      @default(0)
  engagementRate      Decimal  @default(0) @db.Decimal(5, 2)
  isVerified          Boolean  @default(false)
  topCountry          String?
  topCountryPercent   Float?
  malePercent         Float?
  age18PlusPercent    Float?
  bestEngagementRate  Float?
  attributionSource   String?
  experienceLevel     String?
  portfolioVideoUrl   String?
  hasTalkingVideos    Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  igConnections            CreatorIgConnection[]
  fbConnections            CreatorFbConnection[]
  ytConnections            CreatorYtConnection[]
  ttConnections            CreatorTikTokConnection[]
  applications             CampaignApplication[]
  payouts                  Payout[]
  operationalProfile       ClipperOperationalProfile?
  approvedCandidateRecords ClipperCandidate[]         @relation("ApprovedCandidateProfile")
  productionAssignments    ProductionAssignment[]
  payoutRunItems           PayoutRunItem[]

  @@index([primaryGeo])
  @@index([engagementRate])
  @@index([totalFollowers])
  @@index([topCountry])
  @@index([malePercent])
  @@index([age18PlusPercent])
}

model ReferralPayout {
  id                    String              @id @default(cuid())
  referrerId            String
  referrer              User                @relation("ReferrerPayouts", fields: [referrerId], references: [id])
  referredUserId        String
  campaignApplicationId String
  submissionId          String?
  submission            CampaignSubmission? @relation("ReferralPayouts", fields: [submissionId], references: [id])
  amount                Decimal             @db.Decimal(10, 2)
  status                String              @default("pending")
  createdAt             DateTime            @default(now())

  @@index([referrerId])
  @@index([referredUserId])
  @@index([status])
  @@index([referrerId, createdAt])
}

// ─────────────────────────────────────────
// INSTAGRAM CONNECTION (Code-in-Bio)
// ─────────────────────────────────────────

model CreatorIgConnection {
  id                      String               @id @default(cuid())
  creatorProfileId        String
  creatorProfile          CreatorProfile       @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  igUsername              String               @unique
  verificationCode        String               @unique
  isVerified              Boolean              @default(false)
  verifiedAt              DateTime?
  lastCheckedAt           DateTime?
  followerCount           Int?
  profilePicUrl           String?
  igUserId                String?
  accessToken             String?
  accessTokenIv           String?
  tokenExpiresAt          DateTime?
  accountRefreshStatus    AccountRefreshStatus @default(NEVER_REFRESHED)
  lastRefreshAttemptAt    DateTime?
  lastSuccessfulRefreshAt DateTime?
  lastRefreshFailedAt     DateTime?
  lastRefreshErrorCode    String?
  lastRefreshErrorMessage String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  bioVerifications BioVerification[]

  @@unique([creatorProfileId, igUsername])
  @@index([creatorProfileId])
  @@index([isVerified])
  @@index([tokenExpiresAt])
}

// ─────────────────────────────────────────
// FACEBOOK PAGE CONNECTION (OAuth)
// ─────────────────────────────────────────

model CreatorFbConnection {
  id                      String               @id @default(cuid())
  creatorProfileId        String
  creatorProfile          CreatorProfile       @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  fbPageId                String?              @unique
  fbUserId                String?
  pageName                String
  pageHandle              String?
  profilePicUrl           String?
  followerCount           Int?
  accessToken             String?
  accessTokenIv           String?
  tokenExpiresAt          DateTime?
  isVerified              Boolean              @default(false)
  verifiedAt              DateTime?
  lastCheckedAt           DateTime?
  accountRefreshStatus    AccountRefreshStatus @default(NEVER_REFRESHED)
  lastRefreshAttemptAt    DateTime?
  lastSuccessfulRefreshAt DateTime?
  lastRefreshFailedAt     DateTime?
  lastRefreshErrorCode    String?
  lastRefreshErrorMessage String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  bioVerifications BioVerification[]

  @@unique([creatorProfileId, fbPageId])
  @@unique([creatorProfileId, pageHandle])
  @@index([creatorProfileId])
  @@index([tokenExpiresAt])
  @@index([fbUserId])
}

// ─────────────────────────────────────────
// YOUTUBE CONNECTION (OAuth)
// ─────────────────────────────────────────

model CreatorYtConnection {
  id                      String               @id @default(cuid())
  creatorProfileId        String
  creatorProfile          CreatorProfile       @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  channelId               String               @unique
  channelName             String
  profilePicUrl           String?
  subscriberCount         Int?
  videoCount              Int?
  accessToken             String?
  accessTokenIv           String?
  refreshToken            String?
  refreshTokenIv          String?
  tokenExpiresAt          DateTime?
  isVerified              Boolean              @default(true)
  accountRefreshStatus    AccountRefreshStatus @default(NEVER_REFRESHED)
  lastRefreshAttemptAt    DateTime?
  lastSuccessfulRefreshAt DateTime?
  lastRefreshFailedAt     DateTime?
  lastRefreshErrorCode    String?
  lastRefreshErrorMessage String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@unique([creatorProfileId, channelId])
  @@index([creatorProfileId])
  @@index([tokenExpiresAt])
}

// ─────────────────────────────────────────
// TIKTOK CONNECTION (OAuth)
// ─────────────────────────────────────────

model CreatorTikTokConnection {
  id                      String               @id @default(cuid())
  creatorProfileId        String
  creatorProfile          CreatorProfile       @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  tikTokOpenId            String?              @unique
  username                String
  displayName             String?
  profilePicUrl           String?
  followerCount           Int?
  accessToken             String?
  accessTokenIv           String?
  refreshToken            String?
  refreshTokenIv          String?
  tokenExpiresAt          DateTime?
  isVerified              Boolean              @default(false)
  verifiedAt              DateTime?
  lastCheckedAt           DateTime?
  accountRefreshStatus    AccountRefreshStatus @default(NEVER_REFRESHED)
  lastRefreshAttemptAt    DateTime?
  lastSuccessfulRefreshAt DateTime?
  lastRefreshFailedAt     DateTime?
  lastRefreshErrorCode    String?
  lastRefreshErrorMessage String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  demographicSubmissions TikTokDemographicSubmission[]
  bioVerifications       BioVerification[]

  @@unique([creatorProfileId, username])
  @@index([creatorProfileId])
  @@index([tokenExpiresAt])
}

model TikTokDemographicSubmission {
  id                 String                  @id @default(cuid())
  connectionId       String
  connection         CreatorTikTokConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  topCountry         String
  topCountryPercent  Int
  topCountries       Json                    @default("[]")
  malePercent        Int
  femalePercent      Int
  otherPercent       Int                     @default(0)
  ageBuckets         Json
  screenRecordingUrl String
  status             VerificationStatus      @default(PENDING)
  reviewNotes        String?
  reviewedBy         String?
  reviewedAt         DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([connectionId])
  @@index([status])
  @@index([connectionId, status])
}

// ─────────────────────────────────────────
// BIO VERIFICATION
// ─────────────────────────────────────────

enum AccountRefreshStatus {
  NEVER_REFRESHED
  REFRESHING
  SUCCESS
  FAILED
}

model BioVerification {
  id                 String                   @id @default(cuid())
  platform           BioPlatform              @default(INSTAGRAM)
  connectionId       String?
  connection         CreatorIgConnection?     @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  tiktokConnectionId String?
  tiktokConnection   CreatorTikTokConnection? @relation(fields: [tiktokConnectionId], references: [id], onDelete: Cascade)
  fbConnectionId     String?
  fbConnection       CreatorFbConnection?     @relation(fields: [fbConnectionId], references: [id], onDelete: Cascade)
  code               String                   @unique
  status             VerificationStatus       @default(PENDING)
  lastCheckedAt      DateTime?
  verifiedAt         DateTime?
  createdAt          DateTime                 @default(now())

  @@index([connectionId])
  @@index([tiktokConnectionId])
  @@index([fbConnectionId])
  @@index([platform, status])
  @@index([status])
}

enum BioPlatform {
  INSTAGRAM
  TIKTOK
  FACEBOOK
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

// ─────────────────────────────────────────
// NICHE SYSTEM
// ─────────────────────────────────────────

enum Niche {
  FINANCE
  TECH
  MOTIVATION
  FOOD
  HUMOR
  LIFESTYLE
  CASINO
  MEMES
  SPORT
  CLIPS
  GAMING
  OTHER
}

// AGENCY OS: BRANDS & CRM

model Brand {
  id              String      @id @default(cuid())
  name            String
  niche           String?
  website         String?
  instagramHandle String?
  tiktokHandle    String?
  contactName     String?
  contactEmail    String?
  status          BrandStatus @default(PROSPECT)
  owner           String?
  monthlyValue    Decimal     @default(0) @db.Decimal(12, 2)
  currency        String      @default("EUR")
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  onboarding            BrandOnboarding?
  campaigns             Campaign[]
  convertedLeads        BrandLead[]            @relation("ConvertedBrand")
  productionAssignments ProductionAssignment[]
  contractDocuments     ContractDocument[]

  @@index([status])
  @@index([owner])
}

model BrandLead {
  id               String         @id @default(cuid())
  brandName        String
  contactName      String?
  contactEmail     String?
  source           String?
  stage            BrandLeadStage @default(LEAD)
  priority         LeadPriority   @default(MEDIUM)
  owner            String?
  lastContactedAt  DateTime?
  nextFollowUpAt   DateTime?
  estimatedValue   Decimal        @default(0) @db.Decimal(12, 2)
  probability      Int            @default(0)
  notes            String?        @db.Text
  convertedBrandId String?
  convertedBrand   Brand?         @relation("ConvertedBrand", fields: [convertedBrandId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([stage])
  @@index([priority])
  @@index([nextFollowUpAt])
  @@index([convertedBrandId])
}

model BrandOnboarding {
  id                      String                  @id @default(cuid())
  brandId                 String                  @unique
  brand                   Brand                   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  packageName             String?
  monthlyPrice            Decimal                 @default(0) @db.Decimal(12, 2)
  contractSigned          Boolean                 @default(false)
  paymentReceived         Boolean                 @default(false)
  kickoffCallDone         Boolean                 @default(false)
  brandBriefReceived      Boolean                 @default(false)
  contentExamplesReceived Boolean                 @default(false)
  driveFolderCreated      Boolean                 @default(false)
  targetAudience          String?
  mainProductOrService    String?
  hooksAngles             String?                 @db.Text
  dosAndDonts             String?                 @db.Text
  assignedClipperIds      String[]                @default([])
  startDate               DateTime?
  accountManager          String?
  pricingTemplateId       String?
  pricingTemplate         PricingPackageTemplate? @relation(fields: [pricingTemplateId], references: [id])
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([accountManager])
  @@index([startDate])
  @@index([pricingTemplateId])
}

model PricingPackageTemplate {
  id                 String     @id @default(cuid())
  name               String
  description        String?
  price              Decimal    @default(0) @db.Decimal(12, 2)
  currency           String     @default("EUR")
  platforms          Platform[] @default([])
  includedClips      Int?
  includedViews      Int?
  creatorRatePerClip Decimal    @default(0) @db.Decimal(10, 2)
  creatorCpv         Decimal    @default(0) @db.Decimal(8, 6)
  businessCpv        Decimal    @default(0) @db.Decimal(8, 6)
  marginPercent      Decimal    @default(0) @db.Decimal(5, 2)
  isActive           Boolean    @default(true)
  sortOrder          Int        @default(0)
  notes              String?    @db.Text
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  onboardings BrandOnboarding[]
  campaigns   Campaign[]

  @@index([isActive, sortOrder])
}

enum BrandStatus {
  PROSPECT
  ONBOARDING
  ACTIVE
  PAUSED
  CHURNED
}

enum BrandLeadStage {
  LEAD
  CONTACTED
  REPLIED
  CALL_BOOKED
  CALL_DONE
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  NURTURE_LATER
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

// ─────────────────────────────────────────
// CAMPAIGNS
// ─────────────────────────────────────────

model Campaign {
  id                           String         @id @default(cuid())
  name                         String
  slug                         String?        @unique
  platforms                    Platform[]     @default([])
  description                  String?
  contentGuidelines            String?        @db.Text
  referralLink                 String?
  targetGeo                    String[]
  minFollowers                 Int            @default(0)
  minEngagementRate            Decimal        @default(0) @db.Decimal(5, 2)
  totalBudget                  Decimal        @db.Decimal(12, 2)
  creatorCpv                   Decimal        @db.Decimal(8, 6)
  adminMargin                  Decimal        @db.Decimal(8, 6)
  businessCpv                  Decimal        @db.Decimal(8, 6)
  goalViews                    BigInt?
  minimumPaidViews             Int            @default(0)
  maximumPaidViews             Int?
  deadline                     DateTime
  startsAt                     DateTime?
  status                       CampaignStatus @default(draft)
  briefAssetUrl                String?
  discordRoleId                String?        @unique
  discordChannelId             String?        @unique
  discordAnnouncementChannelId String?
  discordAnnouncementMessageId String?        @unique
  discordAnnouncementSentAt    DateTime?

  // Instant claim
  maxSlots         Int?
  claimedSlots     Int     @default(0)
  requiresApproval Boolean @default(false)

  // Brief fields
  targetCountry         String?
  targetCountryPercent  Int?
  targetMinAge18Percent Int?
  targetMalePercent     Int?
  contentType           String?
  requirements          String?
  otherNotes            String?
  pageStats             String?
  minAge                String?
  bannerUrl             String?
  contentAssetUrls      String[]
  guidelinesUrl         String?

  niche           Niche?
  stripePaymentId String?

  // Link-in-bio campaign fields
  bannerVideoUrl    String?
  linkInBioRequired String?
  bioRequirement    String?

  // Content eligibility
  requiredHashtags String[] @default([])

  // Creator/owner
  createdByUserId   String?
  createdBy         User?                   @relation("OwnedCampaigns", fields: [createdByUserId], references: [id])
  brandId           String?
  brand             Brand?                  @relation(fields: [brandId], references: [id])
  pricingTemplateId String?
  pricingTemplate   PricingPackageTemplate? @relation(fields: [pricingTemplateId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications          CampaignApplication[]
  campaignSubmissions   CampaignSubmission[]
  inviteLinks           CampaignInviteLink[]
  referralAttributions  CampaignReferralAttribution[]
  productionAssignments ProductionAssignment[]
  contractDocuments     ContractDocument[]

  @@index([status])
  @@index([deadline])
  @@index([niche])
  @@index([createdByUserId])
  @@index([brandId])
  @@index([pricingTemplateId])
  @@index([discordAnnouncementChannelId])
}

enum CampaignStatus {
  draft
  pending_payment
  pending_review
  active
  paused
  completed
  cancelled
}

enum Platform {
  INSTAGRAM
  TIKTOK
  YOUTUBE_SHORTS
  FACEBOOK
  X
}

// ─────────────────────────────────────────
// CAMPAIGN INVITE LINKS
// ─────────────────────────────────────────

model CampaignInviteLink {
  id         String    @id @default(cuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  token      String    @unique
  maxUses    Int?
  usesCount  Int       @default(0)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([campaignId])
  @@index([token])
}

// ─────────────────────────────────────────
// CAMPAIGN APPLICATIONS
// ─────────────────────────────────────────

model CampaignReferralAttribution {
  id                String    @id @default(cuid())
  campaignId        String
  campaign          Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  referrerId        String
  referrer          User      @relation("CampaignReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referralCode      String
  clickId           String    @unique
  referredUserId    String?
  referredUser      User?     @relation("CampaignReferralUser", fields: [referredUserId], references: [id], onDelete: SetNull)
  clickedAt         DateTime  @default(now())
  signedUpAt        DateTime?
  onboardedAt       DateTime?
  discordLinkedAt   DateTime?
  socialConnectedAt DateTime?
  firstSubmissionAt DateTime?
  activeAt          DateTime?
  firstEarnedAmount Decimal?  @db.Decimal(10, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([campaignId, referredUserId])
  @@index([campaignId])
  @@index([referrerId])
  @@index([campaignId, referrerId])
  @@index([referredUserId])
  @@index([onboardedAt])
  @@index([activeAt])
}

model CampaignApplication {
  id                 String            @id @default(cuid())
  campaignId         String
  campaign           Campaign          @relation(fields: [campaignId], references: [id])
  creatorProfileId   String?
  creatorProfile     CreatorProfile?   @relation(fields: [creatorProfileId], references: [id])
  status             ApplicationStatus @default(pending)
  claimType          ClaimType         @default(INSTANT)
  appliedAt          DateTime          @default(now())
  reviewedAt         DateTime?
  reviewedBy         String?
  reviewNotes        String?
  followerSnapshot   Int?
  engagementSnapshot Decimal?          @db.Decimal(5, 2)

  // Earnings
  earnedAmount       Int       @default(0)
  paidAmount         Int       @default(0)
  lastEarningsCalcAt DateTime?

  updatedAt DateTime @updatedAt

  submissions CampaignSubmission[]
  payouts     Payout[]

  @@index([status])
  @@index([campaignId])
  @@index([creatorProfileId])
}

enum ApplicationStatus {
  pending
  approved
  rejected
  active
  completed
  disputed
}

enum ClaimType {
  INSTANT
  APPLICATION
}

// ─────────────────────────────────────────
// CAMPAIGN SUBMISSIONS (Self-reported views)
// ─────────────────────────────────────────

model CampaignSubmission {
  id                     String                @id @default(cuid())
  applicationId          String
  application            CampaignApplication   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  creatorId              String
  creator                User                  @relation(fields: [creatorId], references: [id])
  campaignId             String
  campaign               Campaign              @relation(fields: [campaignId], references: [id])
  productionAssignmentId String?               @unique
  productionAssignment   ProductionAssignment? @relation(fields: [productionAssignmentId], references: [id])

  postUrl            String
  normalizedPlatform String?
  platformVideoId    String?
  videoUrl           String?
  screenshotUrl      String?
  thumbnailUrl       String?
  mediaType          String?
  claimedViews       Int              @default(0)
  brandMessage  String?          @db.Text
  viewCount     Int?
  likeCount     Int?
  commentCount  Int?
  shareCount    Int?
  baselineViews Int?
  eligibleViews Int?
  status        SubmissionStatus @default(PENDING)

  // Source tracking for bio-verify fallback flow
  sourcePlatform         BioPlatform?
  sourceMethod           SubmissionMethod @default(UNKNOWN)
  authorHandle           String?
  sourceConnectionType   ConnectionType?
  sourceConnectionId     String?
  lastMetricsRefreshAt   DateTime?
  metricsRefreshFailures Int              @default(0)

  reviewedAt    DateTime?
  reviewedBy    String?
  rejectionNote String?
  settledAt     DateTime?

  earnedAmount Decimal @default(0) @db.Decimal(10, 2)

  // ── Subsystem A: tracking foundation ──
  logoStatus     LogoStatus?
  logoVerifiedAt DateTime?
  logoVerifiedBy String?
  velocityScore  Float?
  trustScore     Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referralPayouts   ReferralPayout[]   @relation("ReferralPayouts")
  metricSnapshots   MetricSnapshot[]
  submissionSignals SubmissionSignal[]
  qcReviews         QcReview[]
  payoutRunItems    PayoutRunItem[]

  @@index([applicationId])
  @@index([creatorId])
  @@index([campaignId])
  @@index([status])
  @@index([settledAt])
  @@index([sourceConnectionType, sourceConnectionId])
  @@unique([normalizedPlatform, platformVideoId])
  @@index([logoStatus])
  @@index([productionAssignmentId])
}

enum LogoStatus {
  PENDING
  PRESENT
  MISSING
}

enum SubmissionStatus {
  PENDING
  APPROVED
  NEEDS_REVISION
  REJECTED
  FLAGGED
}

enum SubmissionMethod {
  UNKNOWN
  OAUTH
  BIO_VERIFY
}

// ─────────────────────────────────────────
// PAYOUTS
// ─────────────────────────────────────────

model Payout {
  id                      String               @id @default(cuid())
  creatorProfileId        String?
  creatorProfile          CreatorProfile?      @relation(fields: [creatorProfileId], references: [id])
  applicationId           String?
  application             CampaignApplication? @relation(fields: [applicationId], references: [id])
  payoutRunId             String?
  payoutRun               PayoutRun?           @relation(fields: [payoutRunId], references: [id])
  payoutRunItemId         String?              @unique
  payoutRunItem           PayoutRunItem?       @relation(fields: [payoutRunItemId], references: [id])
  amount                  Decimal              @db.Decimal(12, 6)
  currency                String               @default("EUR")
  status                  PayoutStatus         @default(pending)
  type                    PayoutType           @default(final)
  paymentMethod           PaymentMethod?
  walletAddress           String?
  txHash                  String?
  bankIbanSnapshot        String?
  bankAccountNameSnapshot String?
  bankReference           String?
  coinbaseChargeId        String?
  stripeTransferId        String?
  periodStart             DateTime?
  periodEnd               DateTime?
  applicationIds          String[]
  verifiedViews           Int?
  requestedAt             DateTime?
  initiatedAt             DateTime?
  confirmedAt             DateTime?
  processedAt             DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([applicationId])
  @@index([status])
  @@index([creatorProfileId])
  @@index([payoutRunId])
}

enum PayoutType {
  upfront
  final
}

enum PayoutStatus {
  pending
  processing
  sent
  confirmed
  failed
  disputed
}

enum PaymentMethod {
  CRYPTO
  STRIPE
  BANK_TRANSFER
}

// AGENCY OS: CLIPPERS, PRODUCTION, QC, PAYOUT RUNS, SOPs

model ClipperOperationalProfile {
  id               String             @id @default(cuid())
  creatorProfileId String             @unique
  creatorProfile   CreatorProfile     @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  status           ClipperStatus      @default(APPLICANT)
  reliability      ClipperReliability @default(UNKNOWN)
  maxClipsPerWeek  Int?
  ratePerClip      Decimal            @default(0) @db.Decimal(10, 2)
  editingStyle     String?
  niches           String[]           @default([])
