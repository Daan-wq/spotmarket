{
  "//": "Hobby plan caps Vercel crons at once-per-day. Hot/warm/dispatch crons that need higher cadence run via Supabase pg_cron — see docs/cron-cadence.md. When you upgrade to Vercel Pro, swap the schedules below back to the values in docs/cron-cadence.md and remove the corresponding Supabase pg_cron jobs.",
  "crons": [
    {
      "path": "/api/cron/poll-metrics-hot",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/cron/poll-metrics-warm",
      "schedule": "10 0 * * *"
    },
    {
      "path": "/api/cron/poll-demographics",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/refresh-tokens",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/autopost-scheduler",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/autopost-auto-approve",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/recompute-benchmarks",
      "schedule": "15 0 * * *"
    },
    {
      "path": "/api/cron/recompute-scores",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/notification-dispatch",
      "schedule": "20 0 * * *"
    }
  ]
}
